# Backend Environment Variables Example
# Copy this file to .env and update with your actual values

# ===== SECURITY =====
# JWT Secret Key - MUST be changed in production! Use a strong random key.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production-use-env-variable-instead

# ===== CORS Configuration =====
# Comma-separated list of allowed origins for CORS
# Development default includes common local dev servers
# Production: Set to your actual frontend domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
# For production, use specific domains:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== LLM API Configuration =====
# Gemini API Key for LiteLLM
GEMINI_API_KEY=your-gemini-api-key-here

# ===== Email Configuration (for parent reports) =====
# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Toeho Learning Platform

# ===== Chat Authentication =====
# Set to "true" to require authentication for chat endpoints
CHAT_AUTH_REQUIRED=true

# ===== Database =====
# SQLite database file (default: app.db in backend folder)
# DATABASE_URL=sqlite:///./app.db

# ===== Backblaze B2 (S3-compatible) Configuration =====
# Backblaze offers an S3-compatible endpoint that works with boto3
# Create a B2 bucket and get your credentials at https://www.backblaze.com/b2/cloud-storage.html

# B2 Bucket name
BACKBLAZE_B2_BUCKET_NAME=toeho-videos

# B2 API Token credentials
# Generate at: https://dash.backblaze.com/account/api-tokens
# Required permissions: Object Storage > Read & Write
BACKBLAZE_B2_ACCESS_KEY_ID=your-backblaze-access-key-id
BACKBLAZE_B2_SECRET_ACCESS_KEY=your-backblaze-secret-access-key

# B2 Endpoint URL
# Format: https://<region-string>.backblazeb2.com
BACKBLAZE_B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
BACKBLAZE_B2_REGION=us-east-005

# Optional: Custom domain for CDN delivery
# Set this to your custom domain (e.g., videos.yourdomain.com)
# Cloudflare will serve videos through Cache with this domain
# If not set, falls back to default paid B2 public URL.
STORAGE_CUSTOM_DOMAIN=videos.yourdomain.com

# ===== Video Upload Configuration =====
# Maximum video file size in bytes (default: 500MB)
# For production, consider based on your needs
MAX_VIDEO_SIZE_MB=500

# Multipart upload settings for large files
# Each part must be at least 5 MiB except the last part
MIN_MULTIPART_SIZE_MB=5